# 飞书知识库配置

# === 飞书自建应用凭证 ===
# 在飞书开发者后台 -> 应用信息 -> 凭证与基础信息 中获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === 飞书机器人 Webhook 验证 ===
# 在开发者后台 -> 事件订阅 -> 请求地址验证Token
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# === 飞书资源 ID（由 init.js 创建后自动填入，也可手动填） ===
# 云空间根文件夹 token（用于存放所有归档文件）
# 必填！获取方式：在飞书云空间打开目标文件夹，URL 中 folder/ 后面的字符串即为 token。
# 例如 https://bytedance.feishu.cn/drive/folder/fldbcO1UuPz8VwnpPx5a92abcef
# 则 DRIVE_FOLDER_TOKEN=fldbcO1UuPz8VwnpPx5a92abcef
DRIVE_FOLDER_TOKEN=

# 多维表格 App Token（由 init.js 创建后填入）
BITABLE_APP_TOKEN=

# 多维表格中的资料索引表 ID（由 init.js 创建后填入）
BITABLE_TABLE_ID=

# === AI 配置（用于字段提取）===
# 支持 OpenAI / 混元 / 其他兼容 OpenAI 格式的 API
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# === Bot 服务配置 ===
PORT=3000

# === 机器人名称（用于判断用户是否@了本机器人）===
BOT_NAME=航海助手

# === 监听群配置（单群混合模式）===
# 当前客服与运营共用一个群，填写该群 chat_id 后机器人只处理该群消息。
# 多个群用逗号分隔；留空则监听所有群（测试时方便，生产建议填写）。
MONITORED_CHAT_IDS=

# === 生财 MCP 配置（v3.0 外部资料同步）===
# 打开 https://scys.com/mcp 复制密钥。
# MCP 端点来自生财 MCP 密钥管理页，一般无需修改。
SCYS_MCP_URL=https://mcp.scys.com/shengcai-web/mcp
SCYS_MCP_TOKEN=

# 可选：如果自动选择 MCP 工具不准，可填具体工具名。
SCYS_MCP_MATERIAL_TOOL=

# 可选：默认同步搜索词。
SCYS_MCP_DEFAULT_QUERY=航海 资料 课程 PPT 直播 复盘 SOP 模板 案例 AI

# 可选：是否让机器人启动后自动定时从 MCP 拉取资料（不会主动在群里发消息）
SCYS_MCP_AUTO_SYNC_ENABLED=false
SCYS_MCP_AUTO_SYNC_INTERVAL_MINUTES=360
SCYS_MCP_AUTO_SYNC_STARTUP_DELAY_SECONDS=90
SCYS_MCP_AUTO_SYNC_LIMIT=20
SCYS_MCP_AUTO_SYNC_DRY_RUN=false

