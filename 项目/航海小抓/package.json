{
  "name": "feishu-kb",
  "version": "1.0.0",
  "description": "生财有术飞书知识库 - 自动归档 + 查询",
  "type": "module",
  "scripts": {
    "init": "node scripts/init.js",
    "test-api": "node scripts/test-api.js",
    "audit:library": "node scripts/audit-library.js",
    "doctor": "node scripts/doctor.js",
    "export:knowledge": "node scripts/export-knowledge.js",
    "verify:mcp-manual": "node scripts/verify-mcp-manual.js",
