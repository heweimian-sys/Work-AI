    "library:inspect-quality": "node scripts/inspect-library-quality.js",
    "bot": "node bot/index.js",
    "bot:watch": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/watch-bot-startup.ps1",
    "bot:monitor": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/monitor-bot-startup.ps1",
    "bot:install-startup": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-user-startup.ps1"
