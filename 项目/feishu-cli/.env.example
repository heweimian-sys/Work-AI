FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_OPEN_ID=ou_xxx
FEISHU_OWNER_OPEN_ID=ou_xxx
FEISHU_CLI_DIR=C:\Users\your-name\hermes-agent\scripts
FEISHU_ALLOWED_USERS=ou_xxx
FEISHU_DOMAIN=feishu
FEISHU_CONNECTION_MODE=websocket

GLM_API_KEY=xxx
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 文档 Token 是飞书文档 URL 中 docx/ 后面的字符串。
FEISHU_NOTES_DOC=xxx
FEISHU_CLI_DATA_DIR=~/.hermes/data/feishu-cli

# 可选。本地代理端口不是网页地址，不要在浏览器中直接打开。
FEISHU_CLI_HTTP_PROXY=http://127.0.0.1:10809
